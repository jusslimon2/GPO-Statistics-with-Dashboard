# Copy this file to .env.local and fill the values for your environment.
# Vite requires env vars exposed to client to start with VITE_
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: control popup behavior
# VITE_POPUP_MIN_INTERVAL=10000
# VITE_POPUP_MAX_INTERVAL=30000